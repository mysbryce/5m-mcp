{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "printWidth": 100,
  "endOfLine": "lf",
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    ".claude/**",
    "docs/**",
    "dashboard/**",
    "*.md",
    "**/*.md",
    "**/*.mdx",
    "package.json",
    "package-lock.json",
    "tsconfig.json",
    ".oxlintrc.json",
    ".oxfmtrc.json"
  ]
}

{
  "name": "agent_api",
  "version": "0.0.1",
  "private": true,
  "description": "FiveM resource exposing safe local MCP tools for agentic resource development.",
  "license": "SEE LICENSE IN ./LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mysbryce/5m-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mysbryce/5m-mcp/issues"
  },
  "homepage": "https://github.com/mysbryce/5m-mcp#readme",
  "keywords": [
    "fivem",
    "mcp",
    "model-context-protocol",
    "claude",
    "agent",
    "esx",
    "ox_lib",
    "oxmysql"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "npm run typecheck && npm run lint && npm run fmt:check",
    "smoke": "node scripts/smoke.mjs",
    "smoke:stdio": "node scripts/smoke-stdio.mjs",
    "generate:resource": "node scripts/generate-resource.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:deploy": "vitepress build docs && gh-pages -d docs/.vitepress/dist --dotfiles"
  },
  "devDependencies": {
    "@citizenfx/client": "^2.0.29753-1",
    "@citizenfx/server": "^2.0.29753-1",
    "@types/node": "^20.11.0",
    "esbuild": "^0.21.5",
    "gh-pages": "^6.3.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^5.4.5",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "@overextended/ox_lib": "^3.35.0",
    "@overextended/oxmysql": "^2.14.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  }
}
